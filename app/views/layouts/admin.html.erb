<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Prowl Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
</head>
<body class="min-h-screen bg-gray-100">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <nav class="w-60 bg-gray-900 flex flex-col flex-shrink-0">
      <div class="text-white text-xl font-semibold px-4 py-4 border-b border-gray-700">
        Prowl Admin
      </div>

      <div class="text-gray-500 text-xs uppercase tracking-wider px-4 pt-4 pb-1">Navigation</div>
      <ul class="flex flex-col space-y-0.5 px-2">
        <li>
          <a class="block px-3 py-2 rounded text-sm <%= controller_name == 'dashboard' ? 'text-white bg-blue-600/40' : 'text-gray-400 hover:text-white hover:bg-white/10' %>" href="<%= admin_root_path %>">
            Dashboard
          </a>
        </li>
        <li>
          <a class="block px-3 py-2 rounded text-sm <%= controller_name == 'shops' ? 'text-white bg-blue-600/40' : 'text-gray-400 hover:text-white hover:bg-white/10' %>" href="<%= admin_shops_path %>">
            Shops
          </a>
        </li>
        <li>
          <a class="block px-3 py-2 rounded text-sm <%= controller_name == 'scans' ? 'text-white bg-blue-600/40' : 'text-gray-400 hover:text-white hover:bg-white/10' %>" href="<%= admin_scans_path %>">
            Scans
          </a>
        </li>
        <li>
          <a class="block px-3 py-2 rounded text-sm <%= controller_name == 'issues' ? 'text-white bg-blue-600/40' : 'text-gray-400 hover:text-white hover:bg-white/10' %>" href="<%= admin_issues_path %>">
            Issues
          </a>
        </li>
      </ul>

      <div class="mt-auto p-3 border-t border-gray-700">
        <div class="text-gray-400 text-sm mb-2"><%= current_admin.email %></div>
        <%= link_to "Logout", destroy_admin_session_path, data: { turbo_method: :delete }, class: "block w-full text-center text-sm px-3 py-1.5 border border-gray-500 text-gray-300 rounded hover:bg-gray-700 hover:text-white transition" %>
      </div>
    </nav>

    <!-- Main content -->
    <div class="flex-1 min-w-0">
      <div class="p-6">
        <% if notice.present? %>
          <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-800 rounded-lg">
            <%= notice %>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg">
            <%= alert %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </div>
  </div>
</body>
</html>
