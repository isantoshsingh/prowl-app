<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-bold">Scan #<%= @scan.id %></h2>
  <%= link_to "Back to Scans", admin_scans_path, class: "text-sm px-3 py-1.5 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50" %>
</div>

<!-- Scan Metadata -->
<div class="bg-white rounded-lg shadow-sm mb-6">
  <div class="px-5 py-4 border-b border-gray-200">
    <h5 class="font-semibold text-lg">Scan Details</h5>
  </div>
  <div class="p-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <dl class="space-y-3">
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Shop</dt>
          <dd class="col-span-3"><%= link_to @scan.product_page.shop.shopify_domain, admin_shop_path(@scan.product_page.shop), class: "text-blue-600 hover:underline" %></dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Product Page</dt>
          <dd class="col-span-3"><%= @scan.product_page.title %></dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Status</dt>
          <dd class="col-span-3">
            <% scan_badge = case @scan.status
              when "completed" then "bg-green-100 text-green-800"
              when "failed" then "bg-red-100 text-red-800"
              when "running" then "bg-blue-100 text-blue-800"
              else "bg-gray-100 text-gray-600"
            end %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= scan_badge %>"><%= @scan.status.humanize %></span>
          </dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Scan Depth</dt>
          <dd class="col-span-3"><%= @scan.scan_depth&.humanize || "Quick" %></dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Page Load Time</dt>
          <dd class="col-span-3"><%= @scan.page_load_time_ms ? "#{@scan.page_load_time_ms}ms" : "-" %></dd>
        </div>
      </dl>
      <dl class="space-y-3">
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Created</dt>
          <dd class="col-span-3"><%= @scan.created_at.strftime("%Y-%m-%d %H:%M:%S") %></dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Started</dt>
          <dd class="col-span-3"><%= @scan.started_at&.strftime("%Y-%m-%d %H:%M:%S") || "-" %></dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Completed</dt>
          <dd class="col-span-3"><%= @scan.completed_at&.strftime("%Y-%m-%d %H:%M:%S") || "-" %></dd>
        </div>
        <div class="grid grid-cols-5 gap-2">
          <dt class="col-span-2 text-gray-500 font-medium text-sm">Duration</dt>
          <dd class="col-span-3"><%= @scan.duration_seconds ? "#{@scan.duration_seconds}s" : "-" %></dd>
        </div>
      </dl>
    </div>

    <% if @scan.error_message.present? %>
      <div class="mt-4 p-4 bg-red-50 border border-red-200 text-red-800 rounded-lg">
        <strong>Error:</strong> <%= @scan.error_message %>
      </div>
    <% end %>
  </div>
</div>

<!-- Screenshot -->
<% if @scan.screenshot_url.present? %>
  <div class="bg-white rounded-lg shadow-sm mb-6">
    <div class="px-5 py-4 border-b border-gray-200">
      <h5 class="font-semibold text-lg">Screenshot</h5>
    </div>
    <div class="p-5">
      <img src="<%= @scan.screenshot_url %>" alt="Page screenshot" class="max-w-full border border-gray-200 rounded-lg" style="max-height: 400px;">
    </div>
  </div>
<% end %>

<!-- Issues Detected -->
<div class="bg-white rounded-lg shadow-sm mb-6">
  <div class="px-5 py-4 border-b border-gray-200">
    <h5 class="font-semibold text-lg">Issues Detected (<%= @issues.count %>)</h5>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Issue</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Severity</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Type</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">AI</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @issues.each do |issue| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3"><%= link_to issue.title, admin_issue_path(issue), class: "text-blue-600 hover:underline" %></td>
            <td class="px-5 py-3">
              <% severity_badge = case issue.severity
                when "high" then "bg-red-100 text-red-800"
                when "medium" then "bg-yellow-100 text-yellow-800"
                else "bg-blue-100 text-blue-800"
              end %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= severity_badge %>"><%= issue.severity.humanize %></span>
            </td>
            <td class="px-5 py-3"><%= issue.issue_type.humanize %></td>
            <td class="px-5 py-3">
              <% if issue.ai_confirmed? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Confirmed</span>
              <% elsif issue.ai_confidence.present? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600"><%= issue.ai_confidence.round(0) %>%</span>
              <% else %>
                <span class="text-gray-400">-</span>
              <% end %>
            </td>
            <td class="px-5 py-3"><%= issue.status.humanize %></td>
          </tr>
        <% end %>
        <% if @issues.empty? %>
          <tr>
            <td colspan="5" class="text-gray-400 text-center py-6">No issues detected in this scan.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<!-- Funnel Results -->
<% if @scan.funnel_results.present? && @scan.funnel_results.any? %>
  <div class="bg-white rounded-lg shadow-sm mb-6">
    <div class="px-5 py-4 border-b border-gray-200">
      <h5 class="font-semibold text-lg">Funnel Test Results</h5>
    </div>
    <div class="p-5">
      <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-sm overflow-y-auto" style="max-height: 400px;"><%= JSON.pretty_generate(@scan.funnel_results) %></pre>
    </div>
  </div>
<% end %>

<!-- Raw Logs -->
<div class="bg-white rounded-lg shadow-sm mb-6">
  <div class="px-5 py-4 border-b border-gray-200">
    <h5 class="font-semibold text-lg">JS Errors</h5>
  </div>
  <div class="p-5">
    <% if @scan.parsed_js_errors.any? %>
      <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-sm overflow-y-auto" style="max-height: 300px;"><%= JSON.pretty_generate(@scan.parsed_js_errors) %></pre>
    <% else %>
      <p class="text-gray-400">No JS errors recorded.</p>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow-sm mb-6">
  <div class="px-5 py-4 border-b border-gray-200">
    <h5 class="font-semibold text-lg">Network Errors</h5>
  </div>
  <div class="p-5">
    <% if @scan.parsed_network_errors.any? %>
      <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-sm overflow-y-auto" style="max-height: 300px;"><%= JSON.pretty_generate(@scan.parsed_network_errors) %></pre>
    <% else %>
      <p class="text-gray-400">No network errors recorded.</p>
    <% end %>
  </div>
</div>

<div class="bg-white rounded-lg shadow-sm">
  <div class="px-5 py-4 border-b border-gray-200">
    <h5 class="font-semibold text-lg">DOM Checks Data</h5>
  </div>
  <div class="p-5">
    <% if @scan.parsed_dom_checks_data.any? %>
      <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-sm overflow-y-auto" style="max-height: 300px;"><%= JSON.pretty_generate(@scan.parsed_dom_checks_data) %></pre>
    <% else %>
      <p class="text-gray-400">No DOM checks data recorded.</p>
    <% end %>
  </div>
</div>
