<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-bold">Scans</h2>
</div>

<!-- Filters -->
<div class="bg-white rounded-lg shadow-sm mb-4 p-4">
  <%= form_tag(admin_scans_path, method: :get, class: "grid grid-cols-1 md:grid-cols-12 gap-3 items-end") do %>
    <div class="md:col-span-4">
      <label class="block text-sm text-gray-600 mb-1">Shop Domain</label>
      <%= text_field_tag :shop_domain, params[:shop_domain], class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "Filter by domain..." %>
    </div>
    <div class="md:col-span-3">
      <label class="block text-sm text-gray-600 mb-1">From</label>
      <%= date_field_tag :date_from, params[:date_from], class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
    <div class="md:col-span-3">
      <label class="block text-sm text-gray-600 mb-1">To</label>
      <%= date_field_tag :date_to, params[:date_to], class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
    <div class="md:col-span-2">
      <button type="submit" class="w-full bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 font-medium">Filter</button>
    </div>
  <% end %>
  <% if params[:shop_domain].present? || params[:date_from].present? || params[:date_to].present? %>
    <div class="mt-3">
      <%= link_to "Clear filters", admin_scans_path, class: "text-sm px-3 py-1.5 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>

<!-- Scans Table -->
<div class="bg-white rounded-lg shadow-sm">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="text-left px-5 py-3 font-medium text-gray-600">ID</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Shop</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Product Page</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Status</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Depth</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Load Time</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Issues</th>
          <th class="text-left px-5 py-3 font-medium text-gray-600">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @scans.each do |scan| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3"><%= link_to "##{scan.id}", admin_scan_path(scan), class: "text-blue-600 hover:underline" %></td>
            <td class="px-5 py-3"><%= link_to scan.product_page.shop.shopify_domain, admin_shop_path(scan.product_page.shop), class: "text-blue-600 hover:underline" %></td>
            <td class="px-5 py-3"><%= scan.product_page.title %></td>
            <td class="px-5 py-3">
              <% scan_badge = case scan.status
                when "completed" then "bg-green-100 text-green-800"
                when "failed" then "bg-red-100 text-red-800"
                when "running" then "bg-blue-100 text-blue-800"
                else "bg-gray-100 text-gray-600"
              end %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= scan_badge %>"><%= scan.status.humanize %></span>
            </td>
            <td class="px-5 py-3"><%= scan.scan_depth&.humanize || "Quick" %></td>
            <td class="px-5 py-3"><%= scan.page_load_time_ms ? "#{scan.page_load_time_ms}ms" : "-" %></td>
            <td class="px-5 py-3"><%= scan.issues.count %></td>
            <td class="px-5 py-3"><%= scan.created_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        <% end %>
        <% if @scans.empty? %>
          <tr>
            <td colspan="8" class="text-gray-400 text-center py-6">No scans found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%== pagy_nav(@pagy) if @pagy.pages > 1 %>
